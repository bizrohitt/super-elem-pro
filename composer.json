{
    "name": "rohit/super-elem-pro",
    "description": "A powerful personal Elementor addon plugin by Rohit",
    "type": "wordpress-plugin",
    "license": "GPL-2.0-or-later",
    "authors": [
        {
            "name": "Rohit",
            "role": "Developer & Owner"
        }
    ],
    "minimum-stability": "stable",
    "prefer-stable": true,
    "require": {
        "php": ">=7.4"
    },
    "require-dev": {
        "squizlabs/php_codesniffer": "^3.7",
        "wp-coding-standards/wpcs": "^3.0"
    },
    "autoload": {
        "psr-4": {
            "SuperElemPro\\": "includes/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "SuperElemPro\\Tests\\": "tests/"
        }
    },
    "scripts": {
        "install-codestandards": [
            "phpcs --config-set installed_paths vendor/wp-coding-standards/wpcs"
        ],
        "lint": "phpcs --standard=WordPress includes/",
        "lint-fix": "phpcbf --standard=WordPress includes/",
        "bump": "php bump-version.php patch",
        "bump:minor": "php bump-version.php minor",
        "bump:major": "php bump-version.php major"
    },
    "config": {
        "optimize-autoloader": true,
        "sort-packages": true,
        "allow-plugins": {
            "dealerdirect/phpcodesniffer-composer-installer": true
        }
    },
    "extra": {
        "wordpress-install-dir": "wordpress"
    }
}